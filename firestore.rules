rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Anime Rules
    match /animes/{animeId} {
      allow read: if true;
      allow write: if false; // Only admin via functions/console

      match /episodes/{episodeId} {
        allow read: if true;
      }

      match /chapters/{chapterId} {
        allow read: if true;
      }
    }

    // User Rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);

      match /watchHistory/{animeId} {
        allow read, write: if isOwner(userId) && isValidId(animeId);
      }

      match /readHistory/{mangaId} {
        allow read, write: if isOwner(userId) && isValidId(mangaId);
      }

      match /favorites/{animeId} {
        allow read, write: if isOwner(userId) && isValidId(animeId);
      }
    }
  }
}
